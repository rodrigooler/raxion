    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.10",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "wrangler": "4.80.0"
  },
  "type": "module"
}
